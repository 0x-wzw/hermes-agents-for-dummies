# =====================================
# Hermes Agent v2 — Configuration Template
# =====================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git!
# =====================================

# =====================================
# REQUIRED: Git Identity
# =====================================
GIT_USER_NAME=[YOUR_GIT_USERNAME]
GIT_USER_EMAIL=[YOUR_EMAIL_HERE]

# =====================================
# REQUIRED: GitHub Integration
# =====================================
GITHUB_TOKEN=[YOUR_GITHUB_TOKEN_HERE]

# =====================================
# OPTIONAL: Telegram Integration
# =====================================
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=[YOUR_TELEGRAM_BOT_TOKEN_HERE]

# =====================================
# OPTIONAL: Notion Integration
# =====================================
# Create integration: https://www.notion.so/my-integrations
NOTION_API_KEY=[YOUR_NOTION_API_KEY_HERE]

# =====================================
# Model Routing — Ollama Cloud (Primary)
# =====================================
# Get API key from: https://ollama.com/settings/keys
OLLAMA_API_KEY=[YOUR_OLLAMA_API_KEY_HERE]

# =====================================
# OPTIONAL: Ollama Local (for local inference)
# =====================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# WARNING: OLLAMA_BASE_URL overrides ollama-cloud provider!

# =====================================
# OPTIONAL: Additional Integrations
# =====================================
# CLOUDFLARE_ACCOUNT_ID=[YOUR_CLOUDFLARE_ACCOUNT_ID_HERE]
# CLOUDFLARE_API_TOKEN=[YOUR_CLOUDFLARE_API_TOKEN_HERE]
# HF_TOKEN=[YOUR_HUGGINGFACE_TOKEN_HERE]
# WANDB_API_KEY=[YOUR_WANDB_API_KEY_HERE]

# =====================================
# Logging & Display
# =====================================
# LOG_LEVEL=info