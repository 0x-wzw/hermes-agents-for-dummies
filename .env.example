# =====================================
# Hermes Agent Configuration Template
# =====================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER commit .env to git!
# =====================================

# =====================================
# REQUIRED: GitHub Integration
# =====================================
# Create token at: https://github.com/settings/tokens
# Required scopes: repo, workflow, read:org
GITHUB_TOKEN=[YOUR_GITHUB_TOKEN_HERE]

# Git identity (match your GitHub account)
GIT_USER_NAME="[YOUR_GIT_USERNAME]"
GIT_USER_EMAIL="[YOUR_EMAIL_HERE]"

# =====================================
# OPTIONAL: Telegram Integration
# =====================================
# Create bot via @BotFather on Telegram
telegram__api_key=[YOUR_TELEGRAM_BOT_TOKEN_HERE]

# Get chat ID: https://api.telegram.org/bot[TOKEN]/getUpdates
telegram__chat_id=[YOUR_TELEGRAM_CHAT_ID_HERE]

# =====================================
# OPTIONAL: Discord Integration
# =====================================
# Create app: https://discord.com/developers/applications
discord__bot_token=[YOUR_DISCORD_BOT_TOKEN_HERE]
discord__channel_id=[YOUR_DISCORD_CHANNEL_ID_HERE]

# =====================================
# OPTIONAL: Slack Integration
# =====================================
# Create app: https://api.slack.com/apps
slack__bot_token=[YOUR_SLACK_BOT_TOKEN_HERE]
slack__channel_id=[YOUR_SLACK_CHANNEL_ID_HERE]

# =====================================
# Model Routing Configuration
# =====================================
OLLAMA_API_URL=http://localhost:11434
DEFAULT_MODEL=kimi-k2.5:cloud

# Optional: Ollama Cloud API key
OLLAMA_CLOUD_TOKEN=[YOUR_OLLAMA_CLOUD_TOKEN_HERE]

# =====================================
# Web Search & Research
# =====================================
# Get key: https://tavily.com
TAVILY_API_KEY=[YOUR_TAVILY_API_KEY_HERE]

# =====================================
# Docker Sandbox
# =====================================
ENABLE_DOCKER_SANDBOX=true
DOCKER_SOCKET=/var/run/docker.sock

# =====================================
# Documentation Integrations
# =====================================
# Notion: https://www.notion.so/my-integrations
NOTION_TOKEN=[YOUR_NOTION_INTEGRATION_TOKEN_HERE]
NOTION_DATABASE_ID=[YOUR_NOTION_DATABASE_ID_HERE]

# Linear: https://linear.app/settings/api
LINEAR_API_KEY=[YOUR_LINEAR_API_KEY_HERE]

# =====================================
# ML/AI Integrations
# =====================================
# HuggingFace: https://huggingface.co/settings/tokens
HF_TOKEN=[YOUR_HUGGINGFACE_TOKEN_HERE]

# Weights & Biases
WANDB_API_KEY=[YOUR_WANDB_API_KEY_HERE]

# =====================================
# Logging
# =====================================
LOG_LEVEL=info
LOG_FILE=~/.hermes/logs/hermes.log

# =====================================
# Advanced: Multi-tenancy
# =====================================
# Only needed if running multiple swarms
TENANT_ID=[YOUR_TENANT_ID_HERE]
NAMESPACE=[YOUR_NAMESPACE_HERE]

# =====================================
# Advanced: Custom Endpoints
# =====================================
# Custom model API endpoint (if not using Ollama default)
# CUSTOM_MODEL_API_URL=[YOUR_CUSTOM_MODEL_API_URL_HERE]

# Custom vector DB (for RAG)
# VECTOR_DB_URL=[YOUR_VECTOR_DB_URL_HERE]
# VECTOR_DB_KEY=[YOUR_VECTOR_DB_KEY_HERE]
